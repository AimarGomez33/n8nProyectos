# Configuración de ejemplo para variables de entorno
# Copia este archivo como .env y modifica los valores según tu configuración

# Puerto para la interfaz Gradio
GRADIO_PORT=7860

# Puerto para la API FastAPI
API_PORT=8000

# Configuración de GPU (opcional)
CUDA_VISIBLE_DEVICES=0

# Configuración de Google Drive API (opcional)
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json
